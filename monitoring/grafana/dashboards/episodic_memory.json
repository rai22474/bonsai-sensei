{
  "title": "Episodic Memory — Episodes & Search Metrics",
  "uid": "episodic-memory-metrics",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "tags": ["episodic-memory", "graphiti"],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Episodes Submitted",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(em_episodes_total)",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Episode Success Rate %",
      "type": "stat",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "100 * sum(em_episodes_total{status=\"success\"}) / sum(em_episodes_total)",
          "legendFormat": "Success %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total Memory Searches",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(em_search_requests_total)",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Total Observations Delivered",
      "type": "stat",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(em_observations_returned_total)",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Episode Submission Rate",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(em_episodes_total{status=\"success\"}[5m])",
          "legendFormat": "success/s",
          "refId": "A"
        },
        {
          "expr": "rate(em_episodes_total{status=\"error\"}[5m])",
          "legendFormat": "errors/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "Episode Processing Latency (p50/p90/p99)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(em_episode_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le) (rate(em_episode_duration_seconds_bucket[5m])))",
          "legendFormat": "p90",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(em_episode_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 7,
      "title": "Search Request Rate",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(em_search_requests_total{status=\"success\"}[5m])",
          "legendFormat": "success/s",
          "refId": "A"
        },
        {
          "expr": "rate(em_search_requests_total{status=\"error\"}[5m])",
          "legendFormat": "errors/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "title": "Observations Delivered to Dreamer",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(em_observations_returned_total[30m])",
          "legendFormat": "observations/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "FalkorDB — Memory Used",
      "type": "stat",
      "gridPos": {"x": 0, "y": 20, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "targets": [
        {
          "expr": "redis_memory_used_bytes{job=\"falkordb\"}",
          "legendFormat": "Used",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "FalkorDB — Connected Clients",
      "type": "stat",
      "gridPos": {"x": 6, "y": 20, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "expr": "redis_connected_clients{job=\"falkordb\"}",
          "legendFormat": "Clients",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "FalkorDB — Command Rate",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 20, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(redis_commands_total{job=\"falkordb\"}[5m])",
          "legendFormat": "commands/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "FalkorDB — Memory Over Time",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "targets": [
        {
          "expr": "redis_memory_used_bytes{job=\"falkordb\"}",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "expr": "redis_memory_max_bytes{job=\"falkordb\"}",
          "legendFormat": "max",
          "refId": "B"
        }
      ]
    }
  ]
}
